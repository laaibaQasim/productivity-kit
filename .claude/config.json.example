{
  "enabled": true,

  "sounds_directory": ".claude/sounds",

  "session_tracking": {
    "enabled": true,
    "store_directory": "work-logs",
    "store_name_prefix": "session-work-log",
    "stale_session_days": 7
  },

  "hooks": {
    "task_done": {
      "enabled": true,
      "sound": "task-completed.mp3"
    },
    "permission_needed": {
      "enabled": true,
      "sound": "approval-required.mp3"
    },
    "task_failed": {
      "enabled": true,
      "sound": "task-failed.mp3"
    }
  }
}